{
  "name": "@metacodi/node-ws-io-client",
  "version": "1.1.5",
  "description": "Socket-io Node Websocket Client",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "TS_NODE_PROJECT='./tsconfig.json' ts-node-dev  --inspect --respawn ./src src/index.ts",
    "test": "echo \"No tests yet\"",
    "lint": "eslint . --ext .ts",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm pack --dry-run",
    "prestart": "npm run build",
    "start": "node ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metacodi/node-ws-io-client.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">= 8.0.0"
  },
  "keywords": [
    "socket-io",
    "node",
    "websocket",
    "client"
  ],
  "author": {
    "name": "Metacodi, S.L."
  },
  "contributors": [
    {
      "name": "Jordi Giral",
      "email": "jgiral@metacodi.com"
    },
    {
      "name": "Xavier Giral",
      "email": "xgiral@metacodi.com"
    }
  ],
  "homepage": "https://github.com/metacodi/node-ws-io-client#readme",
  "license": "MIT",
  "dependencies": {
    "@metacodi/node-api-client": "link:../node-api-client",
    "@metacodi/node-utils": "link:../node-utils"
  },
  "peerDependencies": {
    "@metacodi/node-api-client": "1.1.24",
    "@metacodi/node-utils": "^1.0.71",
    "moment": "^2.30.1",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@types/ftp": "^0.3.36",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "commander": "^14.0.3",
    "eslint": "^9.39.4",
    "socket.io": "^4.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}