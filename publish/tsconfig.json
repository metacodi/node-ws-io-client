{
  "compilerOptions": {
    "target": "es2018",
    "lib": ["es2018", "DOM"],
    "module": "commonjs",
    "allowJs": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "resolveJsonModule": false,
    "strictNullChecks": false,
    "typeRoots": [
      "node_modules/@types"
    ],
    "types": ["node"],
    "strict": true,
  },
  "exclude": [
    "node_modules"
  ]
}